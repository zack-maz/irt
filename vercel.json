{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "functions": {
    "api/vercel-entry.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/vercel-entry" },
    { "source": "/health", "destination": "/api/vercel-entry" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
